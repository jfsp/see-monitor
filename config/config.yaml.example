# SEE-Monitor configuration
# Copy to config/config.yaml and adjust. Environment variables override some
# values (SEE_SECRET_KEY, SEE_CONFIG).

# --- Web / storage ---------------------------------------------------------
db_path: data/see_monitor.db
secret_key: ""            # set a long random value, or use SEE_SECRET_KEY env
https_enabled: false      # true only behind a TLS-terminating reverse proxy

# --- Scanning --------------------------------------------------------------
scanning:
  timeout: 10             # per-connection timeout (seconds)
  active_smtp: true       # allow active STARTTLS probing when passive data is
                          # unavailable (Shodan/Censys). Set false for
                          # fully-passive operation.
  dkim_wordlist: true     # probe common DKIM selectors in addition to
                          # per-domain registered selectors
  nameservers: []         # e.g. ["8.8.8.8", "1.1.1.1"]; empty = system default

  # --- v0.6.0 options ------------------------------------------------------
  verify_mx_certs: true   # perform the STARTTLS handshake with PKIX validation
                          # enabled. One connection per MX; a second is made
                          # only when validation fails, to retrieve the
                          # certificate the aborted handshake did not deliver.
  verify_reporting: true  # query the RFC 7489 §7.1 authorisation record for
                          # external DMARC rua/ruf destinations, and confirm
                          # the destination domain resolves
  fcrdns: true            # forward-confirmed reverse DNS on every MX address
  subdomain_check: true   # assess DMARC coverage of live subdomains
  max_subdomains: 25      # names checked per domain (shortest first). Raise for
                          # exhaustive coverage; this is the main driver of
                          # query volume in a community-wide scan.

# --- Scheduling -----------------------------------------------------------
scheduling:
  profiles: []                  # empty = assess against every installed
                                # profile, matching the CLI. Before 0.6.1
                                # scheduled runs scored only the default
                                # profile, so national dashboards went stale.
  post_run_db_check: true       # run the read-only consistency audit after
                                # each scheduled scan; error-level findings are
                                # logged and mark the run completed_with_errors
  reload_interval_minutes: 60   # how often the daemon re-reads scheduled_scans,
                                # so schedules added by scripts/schedule_audit.py
                                # are picked up without a service restart

# --- Reputation / blocklists ----------------------------------------------
# Enabled by default and uses ordinary DNS lookups against public zones.
# NOTE: Spamhaus and others refuse queries arriving from public resolvers or
# large cloud ranges. A refusal is returned as 127.255.255.x and is reported as
# 'blocked' — never as clean and never as listed. For sustained or
# community-scale scanning, obtain a Spamhaus DQS key and replace ip_zones with
# your DQS zones (<key>.zen.dq.spamhaus.net).
dnsbl:
  enabled: true
  ip_zones: []            # empty = built-in defaults (zen.spamhaus.org,
                          # bl.spamcop.net, psbl.surriel.com)
  domain_zones: []        # empty = built-in default (dbl.spamhaus.org)

# --- Certificate Transparency ---------------------------------------------
# crt.sh is queried for subdomain candidates. No API key. Like every passive
# source, results are candidates only and are re-confirmed against
# authoritative DNS before they can affect a score.
crtsh:
  enabled: true

# --- Passive intelligence sources -----------------------------------------
# Shodan is consulted first; Censys is used as an alternative when configured.
shodan:
  api_key: ""

censys:
  api_id: ""
  api_secret: ""

# DNSDumpster (optional) — used ONLY to discover DKIM selector names that are
# hard to guess (e.g. ESP CNAME-delegated selectors). Discovered selectors are
# always re-confirmed with an authoritative DNS lookup before they affect
# scoring; DNSDumpster data is never trusted for scoring directly. Leave empty
# to rely on the common-selector wordlist plus per-domain registered selectors.
dnsdumpster:
  api_key: ""

# SecurityTrails (optional) — passive-DNS database. Used for DKIM selector
# discovery (observed '<selector>._domainkey' subdomains) and as a cross-check
# view of MX / mail-related records. Discovery only; MX and selectors are
# re-confirmed authoritatively before scoring.
securitytrails:
  api_key: ""

# --- Scoring overrides (optional) -----------------------------------------
# Anything set here overrides guidelines/nist_800_177r1.json.
# scoring:
#   weights:
#     dmarc: 0.25
#     spf: 0.15
#     dkim: 0.15
#     starttls: 0.12
#     dnssec: 0.10
#     dane: 0.08
#     mta_sts: 0.08
#     tlsrpt: 0.04
#     bimi: 0.03
#   rating_bands:
#     - {rating: not_implemented, min_score: 0,  label: "Not implemented / Weak"}
#     - {rating: medium,          min_score: 30, label: "Medium"}
#     - {rating: strong,          min_score: 60, label: "Strong"}
#     - {rating: very_strong,     min_score: 85, label: "Very strong"}
